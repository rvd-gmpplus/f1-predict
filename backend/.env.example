# Database (Railway provides this automatically)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Auth
SECRET_KEY=generate-a-secure-random-string-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# OAuth (get from console.cloud.google.com and github.com/settings/developers)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Frontend URL (your Vercel deployment URL)
FRONTEND_URL=https://f1-predict.vercel.app

# ML Pipeline
OPENWEATHERMAP_API_KEY=
FASTF1_CACHE_DIR=/app/fastf1_cache
MODEL_STORAGE_DIR=/app/ml_models

# Scheduler
SCHEDULER_ENABLED=true
DATA_FETCH_DELAY_MINUTES=30
MAX_RETRIES=3
